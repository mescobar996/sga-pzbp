{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "An operational task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["alta", "media", "baja"] },
        "status": { "type": "string", "enum": ["pendiente", "en_proceso", "completado"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string" },
        "authorId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "attachments": { "type": "array", "items": { "type": "object" } },
        "subtasks": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["title", "priority", "status", "createdAt", "authorId"]
    },
    "TaskHistory": {
      "title": "TaskHistory",
      "description": "History of task actions",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "taskTitle": { "type": "string" },
        "action": { "type": "string", "enum": ["completado", "eliminado"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["taskId", "taskTitle", "action", "timestamp", "userId", "userEmail"]
    },
    "Personnel": {
      "title": "Personnel",
      "description": "Technical personnel",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["activo", "inactivo"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["fullName", "role", "status", "createdAt", "authorId"]
    },
    "Visita": {
      "title": "Visita",
      "description": "A registered visit",
      "type": "object",
      "properties": {
        "origen": { "type": "string" },
        "destino": { "type": "string" },
        "fecha": { "type": "string", "format": "date" },
        "hora": { "type": "string", "format": "time" },
        "responsable": { "type": "string" },
        "observaciones": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["origen", "destino", "fecha", "hora", "responsable", "createdAt", "authorId"]
    },
    "Novedad": {
      "title": "Novedad",
      "description": "Office news or notes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" }
      },
      "required": ["title", "content", "createdAt", "authorId", "authorName"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "message", "type", "createdAt", "authorId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks collection"
    },
    "/task_history/{historyId}": {
      "schema": { "$ref": "#/entities/TaskHistory" },
      "description": "Task history collection"
    },
    "/personnel/{personnelId}": {
      "schema": { "$ref": "#/entities/Personnel" },
      "description": "Personnel collection"
    },
    "/visitas/{visitaId}": {
      "schema": { "$ref": "#/entities/Visita" },
      "description": "Visitas collection"
    },
    "/novedades/{novedadId}": {
      "schema": { "$ref": "#/entities/Novedad" },
      "description": "Novedades collection"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Notifications collection"
    }
  }
}
